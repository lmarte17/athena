# Copy this to .env and replace the example values.
# One provider mode should be active at a time.

# ============================================================================
# Provider configuration
# ============================================================================

# ── Option A: Google AI Studio (simplest local development) ──────────────────
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_api_key_here

# ── Option B: Vertex AI (Cloud Run / production / advanced local) ───────────
# Uncomment these and disable Option A when using Vertex AI.
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# Dual-provider mode:
# Keep workspace agents on Vertex AI, but force Live Voice through AI Studio.
# This is the Cloud Run setup used by deploy.sh.
# LIVE_VOICE_FORCE_AI_STUDIO=TRUE
# GOOGLE_API_KEY=your_ai_studio_api_key_here

# ============================================================================
# Model configuration
# ============================================================================

# Live voice model:
# AI Studio uses the date-stamped preview name.
# Vertex AI uses the stable endpoint name shown below.
ATHENA_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# ATHENA_MODEL=gemini-live-2.5-flash-native-audio

# Headless / non-live agents
ATHENA_COORDINATOR_MODEL=gemini-3.1-pro-preview
ATHENA_PLANNER_MODEL=gemini-3.1-pro-preview
ATHENA_SPECIALIST_MODEL=gemini-3.1-flash-lite-preview
ATHENA_DISTILL_MODEL=gemini-3.1-flash-lite-preview

# Memory + retrieval
MEMORY_TAP_MODEL=gemini-3.1-flash-lite-preview
MEMORY_REFLECT_MODEL=gemini-3.1-flash-lite-preview
ATHENA_EMBED_MODEL=gemini-embedding-001
ATHENA_EMBED_DIM=768

# ============================================================================
# LangSmith tracing
# ============================================================================

# Required if you want end-to-end tracing enabled locally.
LANGSMITH_API_KEY=lsv2_your_langsmith_key_here
LANGSMITH_PROJECT=athena-local
# LANGSMITH_PROJECT=athena-cloudrun
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Optional trace controls
# ATHENA_TRACE_ENV=local
ATHENA_TRACE_CAPTURE_THOUGHTS=TRUE
# ATHENA_TRACE_PREVIEW_CHARS=16000

# ============================================================================
# Workspace / gog
# ============================================================================

# Used by workspace tools and Cloud Run deploys.
GOG_ACCOUNT=you@gmail.com

# Only needed for headless / file-based keyring environments such as Cloud Run.
# GOG_KEYRING_BACKEND=file
# GOG_KEYRING_PASSWORD=change_me_if_using_file_keyring

# Optional gog overrides
# ATHENA_GOG_BINARY=/absolute/path/to/gog
# ATHENA_GOG_TIMEOUT_SECS=15

# Optional default calendar override
# ATHENA_CALENDAR_ID=primary

# ============================================================================
# NetBox (nb-cli)
# ============================================================================

# Required for the netbox_specialist to work.
# Install the CLI: pip install nb-cli-tool
NBCLI_URL=https://your-netbox-instance.example.com
NBCLI_TOKEN=your_netbox_api_token_here

# Optional overrides
# ATHENA_NETBOX_CLI=nb-cli          # path/alias if not on PATH
# ATHENA_NETBOX_CLI_TIMEOUT=20      # per-command timeout in seconds

# ============================================================================
# Runtime behavior
# ============================================================================

REFLECTION_IDLE_SECS=120
PROACTIVE_SILENCE_SECS=1.5

# ============================================================================
# Retrieval / storage
# ============================================================================

# ATHENA_INDEX_DB=~/.athena/workspace_index.db

# ============================================================================
# Hydration tuning
# ============================================================================

# ATHENA_HYDRATION_CONCURRENCY=2
# ATHENA_HYDRATION_MAX_RESOURCES_PER_BATCH=2
# ATHENA_HYDRATION_MAX_TEXT_CHARS=12000
# ATHENA_HYDRATION_CHUNK_CHARS=1200
# ATHENA_SHEETS_HYDRATION_MAX_SHEETS=4
# ATHENA_SHEETS_HYDRATION_MAX_ROWS=40
# ATHENA_SHEETS_HYDRATION_MAX_COLS=12
# ATHENA_SLIDES_HYDRATION_MAX_SLIDES=20
